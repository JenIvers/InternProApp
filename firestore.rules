rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /intern_data/{userId} {
      // Allow anyone with the URL to read the data (for the advisor)
      allow read: if true;

      // Strict: Only the authenticated user can write to their own document
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Pre-migration backups: one-time copies of a user's original document,
    // written before a schema upgrade is first persisted. Document id is
    // `{userId}_{ISOtimestamp}` (uid never contains '_'), so the segment
    // before the first '_' is the owner uid. Owner-only read AND write; no
    // public read (unlike intern_data, backups are private to the owner).
    match /intern_data_backups/{backupId} {
      allow read, write: if request.auth != null
        && backupId.split('_')[0] == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
